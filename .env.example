# BeaconAP — environment variables
# Copy this file to .env.local and fill in your values.
# At handoff, set these in Vercel project settings.

# ─── Phase 1: Auth + DB (required to run the app) ──────────────────────────

# A long, random secret used to sign session cookies. Generate with:
#   openssl rand -base64 48
BEACONAP_SESSION_SECRET=

# The single passphrase that unlocks the app for the CEO.
BEACONAP_PASSPHRASE=

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only; keeps RLS bypass for trusted ops)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Phase 1: AI (CEO provides at handoff) ─────────────────────────────────

# Anthropic API key for Claude. Until set, leave demo mode on.
ANTHROPIC_API_KEY=

# Set to "true" while developing without an Anthropic key. Returns canned JSON
# from /api/ai/* routes so the team can demo without burning credit.
ANTHROPIC_DEMO_MODE=true

# Model identifier — default is the current-gen Sonnet.
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Phase 3: Research (activate when CEO buys keys) ───────────────────────

# Search provider for the research pipeline. Defaults to "tavily".
SEARCH_PROVIDER=tavily

TAVILY_API_KEY=
EXA_API_KEY=

# Demo mode for research findings — returns canned briefings until disabled.
RESEARCH_DEMO_MODE=true

# Max research runs per day. Acts as a kill-switch on accidental loops.
MAX_RESEARCH_PER_DAY=50

# ─── Phase 4: Outreach drafting ────────────────────────────────────────────

# Demo mode for outreach drafts — returns canned drafts until disabled.
# Reuses ANTHROPIC_API_KEY for live drafting; flip this off once a key is set.
OUTREACH_DEMO_MODE=true

# ─── Phase 5: Connectors (activate later) ──────────────────────────────────

GRANOLA_API_KEY=
GRANOLA_DEMO_MODE=true

APOLLO_API_KEY=
APOLLO_DEMO_MODE=true

# ─── Phase 6: Email send (activate last) ───────────────────────────────────

# Google Cloud OAuth client (configured at handoff per HANDOFF.md).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft Azure AD app (configured at handoff per HANDOFF.md).
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common

EMAIL_DEMO_MODE=true
